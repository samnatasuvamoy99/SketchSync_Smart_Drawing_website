generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  email    String  @unique
  password String
  photo    String?
  rooms    Room[]  @relation("AdminRooms")
  chats    Chat[]
}

model Room {
  id         String     @id @default(uuid())
  createAt   DateTime   @default(now())
  slug       String?    @unique
  adminId    String
  admin      User       @relation("AdminRooms", fields: [adminId], references: [id])
  chats      Chat[]
  Coordinate Snapshot[]
}

model Chat {
  id        Int      @id @default(autoincrement())
  message   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  createdAt DateTime @default(now())
  
  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
}

model Snapshot {
  id        Int   @id    @default(autoincrement())
  roomId    String
  room      Room   @relation(fields: [roomId], references: [id])
  coordinates      String
  @@index([roomId])
  createdAt DateTime @default(now())
}
